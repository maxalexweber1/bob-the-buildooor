# Copy to .env (gitignored). Never commit real keys.
# Provider API keys are read at runtime from settings; these are for local dev only.
VITE_BLOCKFROST_PROJECT_ID_PREVIEW=
VITE_BLOCKFROST_PROJECT_ID_PREPROD=
VITE_BLOCKFROST_PROJECT_ID_MAINNET=

# Custom / self-hosted Koios base URL (optional). A per-network var wins; else VITE_KOIOS_URL; else
# the public Koios endpoint. Include the API path, e.g. https://my-koios.example/api/v1
VITE_KOIOS_URL=
VITE_KOIOS_URL_PREVIEW=
VITE_KOIOS_URL_PREPROD=
VITE_KOIOS_URL_MAINNET=
